# Frontend environment variables (Vite exposes only VITE_-prefixed vars).
#
# Local development: leave this UNSET. The app falls back to "/api" and Vite's
# dev proxy (vite.config.ts) forwards requests to the backend, avoiding CORS.
#
# Production (e.g. Vercel): set this to your deployed backend's API base URL.
# Must end in /api.
# VITE_API_BASE_URL=https://your-backend.up.railway.app/api
