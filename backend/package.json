{
  "name": "chat-support-backend",
  "private": true,
  "scripts": {
    "local": "nodemon",
    "start": "cross-env NODE_ENV=local ts-node -r tsconfig-paths/register src/server.ts",
    "dev": "npm run build && cross-env NODE_ENV=development node ./dist/server.js",
    "prod": "npm run build && cross-env NODE_ENV=production node ./dist/server.js",
    "build": "prisma generate && tsup src/server.ts --out-dir dist --format cjs",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "lint": "eslint . --ext .ts,.js --max-warnings=0",
    "lint:fix": "eslint --fix --ext .js,.ts .",
    "format": "prettier . -w",
    "format:check": "prettier . --check",
    "postinstall": "prisma generate",
    "prepare": "husky install || true"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint . --ext .ts,.js --max-warnings=0",
      "prettier . -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier . -w"
    ]
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/http-errors": "^2.0.4",
    "@types/morgan": "^1.9.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.2.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript": "*",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.2.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.1",
    "openai": "^6.44.0"
  }
}
