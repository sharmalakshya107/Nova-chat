PORT=8000
NODE_ENV=local

DATABASE_URL="postgresql://user:password@localhost:5432/chat_support?schema=public"
FE_BASE_URL=http://localhost:5173

OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4.1-mini
LLM_MAX_TOKENS=600
LLM_TIMEOUT_MS=15000

# To use OpenRouter (or any OpenAI-compatible API) instead of OpenAI directly,
# set an sk-or-... key above, uncomment the line below, and use a namespaced
# model such as LLM_MODEL=openai/gpt-4.1-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1

CHAT_RATE_LIMIT_MAX=20
